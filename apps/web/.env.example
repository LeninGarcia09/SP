# Frontend Environment Variables
# For local dev, the Vite proxy handles /api → localhost:3000 so this can be empty
# For production/staging: set to the full API URL (e.g. https://api-bizops-prod.azurecontainerapps.io/api/v1)
VITE_API_BASE_URL=

# Azure AD / Microsoft Entra ID (leave empty for dev-mode auth)
# When set, the frontend uses MSAL to authenticate against Azure AD
VITE_AZURE_AD_TENANT_ID=
VITE_AZURE_AD_CLIENT_ID=
VITE_AZURE_AD_REDIRECT_URI=http://localhost:5173
# Production values: tenant=bad76ac5-fba7-4ac7-8776-dda48c50e003, client=a5ab01f4-6cda-42cc-9704-ae3ee9a1c12d
