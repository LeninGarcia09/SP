# App
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database (Docker Compose Postgres)
DATABASE_URL=postgresql://bizops:bizops_dev_pass@localhost:5432/bizops_dev
DATABASE_SSL=false

# JWT (generate a random secret for local dev)
JWT_SECRET=local-dev-secret-change-me-in-production
JWT_EXPIRES_IN=8h

# Azure AD / Microsoft Entra ID
# When BOTH tenant_id and client_id are set, the backend validates Azure AD tokens via JWKS.
# When empty, falls back to local JWT_SECRET validation (dev mode).
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_AUDIENCE=

# Domain restriction (comma-separated, e.g. "yourcompany.com,subsidiary.com")
# Only users with emails from these domains can log in via Azure AD.
# Leave empty to allow all domains in your tenant.
ALLOWED_EMAIL_DOMAINS=

# Azure Storage (Phase 1 — not yet needed)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=attachments

# Redis (Phase 1 — optional for local dev)
REDIS_URL=redis://localhost:6379
